################# NocoCRM 生产环境变量（T17.05）#################
# 复制为 deploy/.env.production 后填写真实值。切勿提交真实 .env.production！

############### 应用 ###############
APP_ENV=production
APP_PORT=13000
# 强随机串，生成：openssl rand -base64 32
APP_KEY=please-change-me-to-a-strong-random-key
# 多核集群模式（worker 数）；启用分布式架构插件后才完全生效
CLUSTER_MODE=2

############### 数据库（指向 compose 内 postgres）###############
DB_DIALECT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=nococrm
DB_USER=nococrm
DB_PASSWORD=please-change-me

############### 缓存 / 队列（Redis）###############
CACHE_DEFAULT_STORE=redis
CACHE_REDIS_URL=redis://redis:6379/0

############### 邮件（客户通知 + 告警）###############
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USER=crm@betterbags.example
SMTP_PASS=please-change-me

############### 日志 ###############
LOGGER_TRANSPORT=dailyRotateFile
LOGGER_LEVEL=info
LOGGER_MAX_FILES=14d
LOGGER_MAX_SIZE=20m

############### 运维告警（plugin-nococrm-ops）###############
OPS_ALERT_EMAIL=ops@betterbags.example
# 钉钉/飞书机器人 webhook（可选）
OPS_ALERT_WEBHOOK=

############### 备份（backup.sh 使用）###############
# 备份保留天数
BACKUP_RETENTION_DAYS=30
# 异地备份（可选，S3 兼容）
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
